---
import '@/styles/global.css';
import type { SEOMeta } from '@/lib/seo';
import { buildTitle } from '@/lib/seo';
import siteDataRaw from '../../public/data/site.json';
import type { SiteData } from '@/types';
const siteData = siteDataRaw as SiteData;
import NavBar from '@/components/sections/NavBar.astro';
import WhatsAppButton from '@/components/ui/WhatsAppButton.astro';
import ScrollToTop from '@/components/ui/ScrollToTop.astro';
import SkipLink from '@/components/ui/SkipLink.astro';
import { ClientRouter } from 'astro:transitions';

interface Props extends SEOMeta {}

const {
  title,
  description,
  canonical,
  ogImage = '/images/logo2.webp',
  noindex = false,
} = Astro.props;

const builtTitle = buildTitle(title);
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();

// JSON-LD LocalBusiness desde el JSON de datos
const schemaLD = JSON.stringify(siteData.localSeo.schemaLocalBusiness);
---

<!doctype html>
<html lang="es-PE" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#810FC9" />
    <ClientRouter />

    <!-- SEO Primary -->
    <title>{builtTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={builtTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale"      content="es_PE" />
    <meta property="og:site_name"   content={siteData.name} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={builtTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={new URL(ogImage, Astro.site).toString()} />

    <!-- Preload Critical Assets -->
    <link rel="preload" href="/fonts/Inter-VariableFont_opsz,wght.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/Calistoga-Regular.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/images/bannerfinal.png" as="image" />

    <!-- Favicon -->
    <link rel="icon"             href="/favicon.ico" sizes="any" />
    <!-- <link rel="icon"             href="/favicon.svg" type="image/svg+xml" /> -->
    <!-- <link rel="apple-touch-icon" href="/apple-touch-icon.png" /> -->

    <!-- LocalBusiness schema base si no se sobrecarga en el slot head -->
    <script is:inline type="application/ld+json" set:html={schemaLD}></script>

    <!-- Slot meta tags adicionales por página (BreadcrumbList, AggregateRating, etc.) -->
    <slot name="head" />
  </head>

  <body class="bg-light-surface text-dark font-body antialiased">
    <SkipLink />
    <NavBar />
    <slot />
    <WhatsAppButton position="bottom-right" />

    <ScrollToTop position="right" />
  </body>
</html>
