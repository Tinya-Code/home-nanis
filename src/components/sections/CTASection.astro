---
// src/components/sections/CTASection.astro
import ButtonPrimary from '@/components/ui/ButtonPrimary.astro';
import siteDataRaw from '../../../public/data/site.json';
import { buildWhatsAppLink } from '@/lib/formatters';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import nurseImg from '@/assets/enfermera.png';
import nannyImg from '@/assets/nana.png';
import type { SiteData } from '@/types';

const siteData = siteDataRaw as unknown as SiteData;
const phone = siteData.contact.whatsapp;
const defaultMessage = "Hola El Hogar de Nanis, me gustaría recibir información sobre sus servicios de personal doméstico.";
const defaultWhatsAppUrl = buildWhatsAppLink(phone, defaultMessage);

interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  variant?: 'primary' | 'dark' | 'light' | 'image';
  primaryButton?: {
    label: string;
    href: string;
    variant?: any;
    icon?: string;
    external?: boolean;
  };
  secondaryButton?: {
    label: string;
    href: string;
    variant?: any;
    icon?: string;
    external?: boolean;
  };
  iconLarge?: string;
  class?: string;
  id?: string;
}

const { 
  title = "¿Lista para encontrar a la persona ideal?", 
  subtitle,
  description = "Déjanos ayudarte a seleccionar a la candidata perfecta con la seguridad y respaldo que tu familia limeña merece. ¡Hablemos hoy!",
  variant = 'primary',
  primaryButton = {
    label: "Escríbenos por WhatsApp",
    href: defaultWhatsAppUrl,
    variant: "whatsapp",
    external: true
  },
  secondaryButton,
  iconLarge,
  class: className = '',
  id = "contacto-rapido"
} = Astro.props;

const variantClasses = {
  primary: 'bg-brand text-white',
  dark: 'bg-dark text-white border border-white/5',
  light: 'bg-light-surface text-dark border border-border',
  image: 'bg-dark text-white relative'
};

const textEmphasis = {
  primary: 'text-white/90',
  dark: 'text-gray-light/80',
  light: 'text-gray-muted',
  image: 'text-white/80'
};
---

<section 
  class:list={[
    "section-padding py-12 relative overflow-hidden",
    variantClasses[variant],
    className
  ]} 
  id={id}
>
  {/* Modern background elements based on variant */}
  {variant === 'primary' && (
    <>
      <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 bg-brand-alt/30 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2 pointer-events-none"></div>
    </>
  )}

  {variant === 'dark' && (
    <div class="absolute inset-0 bg-gradient-to-r from-brand/20 to-transparent opacity-50 pointer-events-none"></div>
  )}

  <div class="container-site  relative z-10">
    <div class:list={[
      "max-w-6xl mx-auto flex flex-col lg:flex-row items-center justify-between ",
      { "text-center lg:text-left": variant === 'dark' || variant === 'image' },
      { "text-center": variant === 'primary' || variant === 'light' }
    ]}>
      
      {variant === 'primary' && (
        <div class="hidden lg:block w-1/4 animate-float opacity-90 hover:opacity-100 transition-opacity duration-500">
          <Image 
            src={nurseImg} 
            alt="Enfermera de El Hogar de Nanis" 
            class="w-full -scale-x-100  h-auto object-contain drop-shadow-[0_20px_35px_rgba(0,0,0,0.3)] filter contrast-[1.05]"
            width={400}
            height={600}
          />
        </div>
      )}

      <div class:list={[
        "flex-1 z-10",
        { "lg:w-1/2": variant === 'primary' },
        { "md:w-2/3": variant === 'dark' || variant === 'image' }
      ]}>
        {subtitle && (
          <span class="text-brand-alt text-xs font-bold uppercase tracking-widest mb-4 block animate-fade-in">
            {subtitle}
          </span>
        )}
        <h2 class:list={[
          "font-display font-extrabold mb-6 leading-tight",
          { "text-3xl md:text-4xl": variant === 'primary' || variant === 'light' },
          { "text-3xl md:text-5xl": variant === 'dark' || variant === 'image' }
        ]}>
          {title}
        </h2>
        
        <p class:list={[
          "text-lg mb-10 max-w-2xl",
          textEmphasis[variant],
          { "mx-auto": variant === 'primary' || variant === 'light' }
        ]}>
          {description}
        </p>
        
        <div class:list={[
          "flex flex-col gap-2 sm:flex-row ",
          { "justify-center": variant === 'primary' || variant === 'light' }
        ]}>
          <ButtonPrimary 
            label={primaryButton.label} 
            href={primaryButton.href} 
            variant={primaryButton.variant || (variant === 'light' ? 'primary' : 'primary')} 
            size="lg"
            external={primaryButton.external}
            class="w-full sm:w-auto shadow-xl"
          >
            {primaryButton.variant === 'whatsapp' && (
              <span slot="icon-left" class="mr-2 inline-flex items-center">
                <Icon name="mdi:whatsapp" class="w-5 h-5" />
              </span>
            )}
            {primaryButton.icon && <Icon name={primaryButton.icon} slot="icon-right" class="w-5 h-5 ml-2" />}
          </ButtonPrimary>

          {(secondaryButton || variant === 'primary') && (
            <ButtonPrimary 
              label={secondaryButton?.label || "Llámanos ahora"} 
              href={secondaryButton?.href || `tel:${phone}`} 
              variant={secondaryButton?.variant || (variant === 'primary' ? 'ghost' : 'outline')} 
              size="lg"
              external={secondaryButton?.external}
              class:list={[
                "w-full sm:w-auto",
                { "text-white hover:bg-white/10": variant === 'primary' || variant === 'dark' }
              ]}
            >
              {secondaryButton?.icon && <Icon name={secondaryButton.icon} slot="icon-right" class="w-5 h-5 ml-2" />}
            </ButtonPrimary>
          )}
        </div>
      </div>

      {variant === 'primary' && (
        <div class="hidden lg:block w-1/4 animate-float-delayed opacity-90 hover:opacity-100 transition-opacity duration-500">
          <Image 
            src={nannyImg} 
            alt="Nana de El Hogar de Nanis" 
            class="w-full h-auto object-contain drop-shadow-[0_20px_35px_rgba(0,0,0,0.3)] filter contrast-[1.05]"
            width={400}
            height={600}
          />
        </div>
      )}

      {(iconLarge || variant === 'dark') && (
        <div class="hidden md:flex md:w-1/3 justify-center">
          <div class="relative">
             <div class="w-48 h-48 rounded-full bg-brand/20 blur-2xl absolute inset-0 animate-pulse"></div>
             <div class="w-48 h-48 rounded-3xl bg-white/5 border border-white/10 backdrop-blur-sm flex items-center justify-center rotate-6 hover:rotate-0 transition-transform duration-700">
                <Icon name={iconLarge || "lucide:file-user"} class="w-24 h-24 text-brand-alt" />
             </div>
          </div>
        </div>
      )}
    </div>
  </div>
</section>


