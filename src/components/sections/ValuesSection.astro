---
// src/components/sections/ValuesSection.astro
import InfoCard from '@/components/ui/InfoCard.astro';
import type { ValueItem } from '@/types/quienes-somos';

interface Props {
  values: ValueItem[];
}

const { values } = Astro.props;
---

<section class="section-padding bg-section-alt">
  <div class="container-site">
    <div class="section-header-centered">
      <span class="section-eyebrow">Nuestros Pilares</span>
      <h2 class="section-title-gradient">Valores que nos guían</h2>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-12">
      {values.map((item) => (
        <InfoCard 
          title={item.title} 
          description={item.description} 
          icon={item.icon} 
   
          centered 
        />
      ))}
    </div>
  </div>
</section>
