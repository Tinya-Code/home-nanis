---
// src/components/sections/PageHeader.astro
import { Icon } from 'astro-icon/components';

interface Breadcrumb {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  subtitle?: string;
  variant?: 'default' | 'image' | 'dark' | 'simple' | 'gradient-bg';
  align?: 'left' | 'center' | 'right';
  size?: 'sm' | 'md' | 'lg';
  backgroundImage?: string;
  breadcrumbs?: Breadcrumb[];
  overlayOpacity?: number;
}

const { 
  title, 
  subtitle, 
  variant = 'default', 
  align = 'center', 
  size = 'md',
  backgroundImage,
  breadcrumbs = [],
  overlayOpacity = 0.6
} = Astro.props;

const alignmentClasses = {
  left: 'text-left items-start',
  center: 'text-center items-center',
  right: 'text-right items-end'
};

const sizeClasses = {
  sm: 'pt-24 pb-12 lg:pt-32 lg:pb-16',
  md: 'pt-32 pb-16 lg:pt-40 lg:pb-24',
  lg: 'pt-40 pb-24 lg:pt-56 lg:pb-40'
};

const variantClasses = {
  default: 'bg-hero',
  image: 'relative bg-dark',
  dark: 'bg-dark',
  simple: 'bg-white border-b border-border',
  'gradient-bg': 'bg-gradient-to-br from-brand via-brand-alt to-accent'
};

// Check if we should use the gradient title (standard for this site)
const useGradientTitle = variant !== 'image' && variant !== 'gradient-bg';
---

<header 
  class:list={[
    'page-header relative overflow-hidden', 
    variantClasses[variant], 
    sizeClasses[size]
  ]}
  style={variant === 'image' && backgroundImage ? `background-image: url('${backgroundImage}'); background-size:cover; background-position:center;` : ''}
>
  {variant === 'image' && (
    <div 
      class="absolute inset-0 bg-black/60 z-0" 
      style={`opacity: ${overlayOpacity}`}
    ></div>
  )}

  <div class:list={['container-site relative z-10 flex flex-col', alignmentClasses[align]]}>
    
    {breadcrumbs.length > 0 && (
      <nav class="flex mb-6 animate-fade-in" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2 text-xs font-medium uppercase tracking-widest">
          <li>
            <a href="/" class="text-white/60 hover:text-white transition-colors">Inicio</a>
          </li>
          {breadcrumbs.map((crumb) => (
            <li class="flex items-center space-x-2">
              <Icon name="lucide:chevron-right" class="w-3 h-3 text-white/30" />
              {crumb.href ? (
                <a href={crumb.href} class="text-white/60 hover:text-white transition-colors">{crumb.label}</a>
              ) : (
                <span class="text-brand-alt">{crumb.label}</span>
              )}
            </li>
          ))}
        </ol>
      </nav>
    )}

    <h1 class:list={[
      'mb-6 animate-fade-up font-display font-bold leading-tight',
      useGradientTitle ? 'section-title-gradient text-4xl md:text-5xl lg:text-6xl' : 'text-white text-4xl md:text-5xl lg:text-7xl',
      { 'max-w-4xl mx-auto': align === 'center' }
    ]}>
      {title}
    </h1>

    {subtitle && (
      <p class:list={[
        'animate-fade-up [animation-delay:200ms] leading-relaxed max-w-2xl',
        variant === 'simple' ? 'text-gray italic text-lg' : 'text-white/90 text-lg md:text-xl',
        { 'mx-auto': align === 'center' }
      ]}>
        {subtitle}
      </p>
    )}
    
    <slot name="after-subtitle" />
  </div>
</header>

