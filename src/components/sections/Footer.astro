---
// src/components/sections/Footer.astro

import { Icon } from 'astro-icon/components';
import siteDataRaw from '../../../public/data/site.json';
import footerData from '../../../public/data/footer.json';
import type { SiteData } from '@/types';
import CopyButton from '@/components/ui/CopyButton.astro';

/**
 * Footer
 * ─────────────────
 * Descripción: Footer altamente configurable con gestión centralizada de datos y enlaces inteligentes.
 * Mejora la experiencia multi-página resolviendo anclas dinámicamente.
 */

interface Props {
  variant?: 'light' | 'dark' | 'glass';
  className?: string;
}

const { 
  variant = 'light',
  className = ''
} = Astro.props;

const siteData = siteDataRaw as SiteData;
const { contact, name, slogan } = siteData;
const year = new Date().getFullYear();
const currentPath = Astro.url.pathname;

// Lógica inteligente para resolver enlaces (anchors funcionan entre páginas)
const resolveHref = (href: string, isAnchor?: boolean) => {
  if (isAnchor && href.startsWith('#')) {
    return currentPath === '/' ? href : `/${href}`;
  }
  return href;
};

const iconMap: Record<string, string> = {
  facebook: 'mdi:facebook',
  instagram: 'mdi:instagram',
  tiktok: 'mdi:music-note',
  youtube: 'mdi:youtube',
  twitter: 'mdi:twitter',
  x: 'mdi:alpha-x',
  linkedin: 'mdi:linkedin',
  whatsapp: 'mdi:whatsapp',
};

const getSocialIcon = (platform: string) =>
  iconMap[platform?.toLowerCase()] ?? 'mdi:link-variant';

// Estilos por variante
const variantStyles = {
  light: 'bg-white border-t border-border',
  dark: 'bg-dark text-white border-t border-white/10',
  glass: 'bg-white/95 backdrop-blur-md border-t border-border'
};

const textStyles = {
  light: 'text-gray hover:text-brand-alt',
  dark: 'text-white/70 hover:text-brand',
  glass: 'text-gray hover:text-brand-alt'
};

const titleStyles = {
  light: 'text-dark',
  dark: 'text-white',
  glass: 'text-dark'
};
---

<footer class:list={[variantStyles[variant], "pt-16 pb-8", className]}>
  <div class="container-site">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
      {/* Columna 1: Marca */}
      <div class="flex flex-col gap-4 items-center sm:items-start text-center sm:text-left">
        <a href="/" class="transition-transform hover:scale-105 duration-300" aria-label={`Ir a inicio de ${name}`}>
          <img src="/images/logo2.webp" alt={`Logo ${name}`} class="w-24 md:w-32 h-auto" />
        </a>
        <p class:list={["text-sm max-w-[280px]", variant === 'dark' ? 'text-white/60' : 'text-gray text-pretty']}>
          {slogan}
        </p>
        
        {/* Redes sociales */}
        <div class="flex items-center gap-3 mt-4">
          {siteData.socialMedia && siteData.socialMedia.map(social => (
            <a 
              href={social.url} 
              target="_blank" 
              rel="noopener noreferrer"
              class:list={[
                "w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300",
                variant === 'dark' 
                  ? "bg-white/5 text-white/70 hover:bg-brand hover:text-white" 
                  : "bg-surface-alt text-gray hover:bg-brand hover:text-white"
              ]}
              aria-label={`Síguenos en ${social.platform}`}
            >
              <Icon name={getSocialIcon(social.platform)} class="w-5 h-5" aria-hidden="true" />
            </a>
          ))}
        </div>
      </div>

      {/* Columnas Dinámicas (Enlaces) */}
      {footerData.columns.map(column => (
        <div class="text-center sm:text-left">
          <h3 class:list={["font-display font-bold mb-6", titleStyles[variant]]}>
            {column.title}
          </h3>
          <ul class="flex flex-col gap-3">
            {column.links.map(link => (
              <li>
                <a 
                  href={resolveHref(link.href, link.isAnchor)} 
                  class:list={["text-sm transition-colors duration-200", textStyles[variant]]}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      {/* Columna 4: Contacto */}
      <div class="text-center sm:text-left">
        <h3 class:list={["font-display font-bold mb-6", titleStyles[variant]]}>
          Contacto
        </h3>
        <ul class="flex flex-col gap-4 mb-8">
          <li class="flex flex-col sm:flex-row items-center sm:items-start justify-between group/contact gap-2">
            <div class="flex items-start gap-3">
              <Icon name="lucide:phone" class="w-5 h-5 text-brand shrink-0 mt-0.5" aria-hidden="true" />
              <span class:list={["text-sm", variant === 'dark' ? 'text-white/70' : 'text-gray']}>
                {contact.phone}
              </span>
            </div>
            <CopyButton 
              textToCopy={contact.phone.replace(/\s/g, '')} 
              label="Copiar" 
              size="sm"
              class="sm:opacity-0 group-hover/contact:opacity-100 transition-opacity"
            />
          </li>
          <li class="flex flex-col sm:flex-row items-center sm:items-start justify-between group/contact gap-2">
            <div class="flex items-start gap-3">
              <Icon name="lucide:mail" class="w-5 h-5 text-brand shrink-0 mt-0.5" aria-hidden="true" />
              <span class:list={["text-sm overflow-hidden text-ellipsis w-full max-w-[200px] sm:max-w-none", variant === 'dark' ? 'text-white/70' : 'text-gray']}>
                {contact.email}
              </span>
            </div>
            <CopyButton 
              textToCopy={contact.email} 
              label="Copiar" 
              size="sm"
              class="sm:opacity-0 group-hover/contact:opacity-100 transition-opacity"
            />
          </li>
          <li class="flex items-start justify-center sm:justify-start gap-3">
            <Icon name="lucide:map-pin" class="w-5 h-5 text-brand shrink-0 mt-0.5" aria-hidden="true" />
            <span class:list={["text-sm", variant === 'dark' ? 'text-white/70' : 'text-gray']}>
              {contact.address}
            </span>
          </li>
        </ul>

        {/* Libro de Reclamaciones */}
        <div class:list={["pt-6 border-t", variant === 'dark' ? 'border-white/10' : 'border-border/50']}>
          <a 
            href={contact.libroReclamacionesLink}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              "flex items-center gap-3 p-3 rounded-xl border border-dashed transition-all duration-300 group/libro",
              variant === 'dark' 
                ? "border-white/20 hover:border-brand/50 hover:bg-white/5" 
                : "border-border/60 hover:border-brand/40 hover:bg-brand/5"
            ]}
          >
            <img 
              src="/images/libro_de_reclamaciones-300x206.png" 
              alt="Libro de Reclamaciones Virtual" 
              class="w-10 h-auto"
            />
            <div class="flex flex-col text-left">
              <span class="text-[10px] font-bold text-gray-muted uppercase tracking-widest whitespace-nowrap">Libro de</span>
              <span class:list={["text-xs font-bold transition-colors", variant === 'dark' ? 'text-white group-hover:text-brand' : 'text-dark group-hover:text-brand']}>
                Reclamaciones
              </span>
            </div>
          </a>
        </div>
      </div>

    </div>

    <div class:list={["h-px w-full mb-8", variant === 'dark' ? 'bg-white/10' : 'bg-border/50']}></div>

    <div class:list={["flex flex-col md:flex-row items-center justify-between gap-6 text-xs", variant === 'dark' ? 'text-white/40' : 'text-gray-muted']}>
      <p>&copy; {year} {name}. Todos los derechos reservados.</p>
      <div class="flex flex-wrap items-center justify-center gap-6">
        {footerData.legal.map(link => (
          <a href={link.href} class:list={["transition-colors", variant === 'dark' ? 'hover:text-white' : 'hover:text-dark']}>
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
