---
// src/components/sections/MethodsIntro.astro
interface Props {
  description: string;
}

const { description } = Astro.props;
---

<section class="section-padding bg-white">
  <div class="container-site max-w-4xl text-center">
    <p class="text-xl text-gray leading-relaxed italic animate-fade-up">
      "{description}"
    </p>
  </div>
</section>
