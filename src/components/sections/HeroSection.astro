---
// src/components/sections/HeroSection.astro

import ButtonPrimary from '@/components/ui/ButtonPrimary.astro';
import heroBg from '@assets/hero-bg.jpeg';
import { Image } from 'astro:assets';
import siteData from '../../../public/data/site.json';

const { slogan } = siteData;

const {
  description = slogan,
  primaryCta = "Contratar Personal",
  primaryCtaLink = "/contacto",
  secondaryCta = "Nuestros Servicios",
  secondaryCtaLink = "/nuestros-servicios",
} = Astro.props;
---

<section class="hero-wrapper">

  <div class="hero flex flex-col">

    <!-- Background Image -->
    <div class="hero-bg">
      <Image
        src={heroBg}
        alt="Servicios domésticos profesionales"
        width={1920}
        height={1080}
        format="webp"
        quality={85}
        class="hero-bg-img object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hero-overlay"></div>
    </div>

    <div class=" relative z-2 md:px-16 px-6 flex justify-start h-full flex-1 items-center">
      <!-- TEXT -->
      <div class="hero-content flex flex-col gap-4">
        <h1 class="hero-title">
          Confianza y Seguridad
          <span>para tu Familia</span>
        </h1>
        <p class="hero-description">
          {description}
        </p>
        <div class="hero-buttons">
          <ButtonPrimary
            label={primaryCta}
            href={primaryCtaLink}
            variant="outline"
            size="lg"
            class="font-medium"
          />
          <ButtonPrimary
            label={secondaryCta}
            href={secondaryCtaLink}
            variant="primary"
            size="lg"
            class="font-medium"
          />
        </div>

        <!-- Trust indicators -->

        <div class="hero-trust">

          <div class="trust-item">

            <div class="trust-icon">

              <svg viewBox="0 0 24 24" fill="none">
                <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2"/>
              </svg>

            </div>

            <span>Personal verificado</span>

          </div>

          <div class="trust-item">

            <div class="trust-icon">
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M12 3l8 4v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V7l8-4z" stroke="currentColor" stroke-width="2"/>
              </svg>
            </div>
            <span>Garantía de servicio</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>

/* WRAPPER (MARCO BLANCO) */

.hero-wrapper{
  background:white;
  padding:20px;
}

/* HERO */
.hero{
  position:relative;
  min-height:85vh;
  border-radius:28px;
  overflow:hidden;
}

/* BACKGROUND */
.hero-bg{
  position:absolute;
  height:100%;
  inset:0;
}

.hero-bg-img{
  width:100%;
  height:100%;
  object-fit:cover;
}

/* CONTENT */
.hero-content{
  max-width:560px;
}

/* TITLE */
.hero-title{
  font-size:clamp(2.6rem,4vw,3.8rem);
  font-weight:800;
  line-height:1.1;
  color:var(--color-dark);
  margin-bottom:20px;
}
.hero-title span{
  display:block;
  color:var(--color-brand);
}
/* DESCRIPTION */
.hero-description{
  font-size:1.15rem;
  line-height:1.7;
  color:var(--color-gray);
  margin-bottom:34px;
}

/* BUTTONS */

.hero-buttons{
  display:flex;
  gap:16px;
  flex-wrap:wrap;
  margin-bottom:32px;
}

/* TRUST */
.hero-trust{
  display:flex;
  gap:26px;
}

.trust-item{
  display:flex;
  align-items:center;
  gap:10px;
  font-size:.95rem;
  font-weight:500;
  color:#374151;
}

/* ICON */
.trust-icon{
  width:32px;
  height:32px;
  border-radius:10px;
  display:flex;
  align-items:center;
  justify-content:center;
  background:#f3f4f6;
  color:var(--color-brand);
}

.trust-icon svg{
  width:18px;
  height:18px;
}

/* RESPONSIVE */

@media(max-width:768px){
  .hero{
    min-height:70vh;
  }
  .hero-content{
    text-align:center;
    margin:auto;
  }

  .hero-buttons{
    justify-content:center;
  }
  .hero-trust{
    justify-content:center;
  }

  .hero-overlay{
    height:100%;
    position:absolute;
    inset:0;
    background:
    rgba(255,255,255,0.5); 
  }

  .hero-wrapper{
  background:white;
  padding:0px;
}

/* HERO */
.hero{
  position:relative;
  min-height:85vh;
  border-radius:0px;
  overflow:hidden;
}
}


</style>