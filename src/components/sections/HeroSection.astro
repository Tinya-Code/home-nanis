---
// src/components/sections/HeroSection.astro
import ButtonPrimary from '@/components/ui/ButtonPrimary.astro';
import heroBg from '@assets/hero-bg.jpeg';
import bannerPrincipal from '@assets/banner-principal.jpeg';
import bannerSecundario from '@assets/banner-secundario.png';
import bannerTercero from '@assets/banner-terceario.png';
import bannerCuarto from '@assets/banner-4.jpeg';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import siteData from '@/data/site.json';
const { slogan } = siteData;
const {
  description = slogan,
  primaryCta = "Contratar Personal",
  primaryCtaLink = "#contacto",
  secondaryCta = "Nuestros Servicios",
  secondaryCtaLink = "#servicios",
} = Astro.props;
---
<section class="hero-wrapper">
  <div class="hero flex flex-col">
    <!-- Background Image -->
    <div class="hero-bg ">
      <Image
        src={bannerCuarto}
        alt="Servicios domésticos profesionales"
        width={1920}
        height={1080}
        format="webp"
        quality={85}
        class="hero-bg-img opacity-90 md:opacity-100 object-right left-3 object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hero-overlay"></div>
    </div>
    <div class="relative w-full max-w-7xl mx-auto z-2 md:px-16 flex justify-start h-full flex-1 items-center">
      <div class="hero-content flex flex-col gap-4">
        <!-- TITLE -->
        <h1 class="hero-title hero-anim hero-anim-title font-display font-semibold leading-tight tracking-tight relative z-10 text-3xl md:text-4xl lg:text-5xl text-dark bg-gradient-to-r from-brand to-brand-alt bg-clip-text text-transparent">
          Confianza y Seguridad
          <span>para tu Familia</span>
        </h1>
        <!-- DESCRIPTION -->
        <p class="hero-description hero-anim hero-anim-desc">
          {description}
        </p>
        <!-- BUTTONS -->
        <div class="hero-buttons hero-anim hero-anim-buttons">
          <ButtonPrimary
            label={primaryCta}
            href={primaryCtaLink}
            variant="outline"
            size="lg"
            class="font-medium"
          />
          <ButtonPrimary
            label={secondaryCta}
            href={secondaryCtaLink}
            variant="primary"
            size="lg"
            class="font-medium"
          />
        </div>
        <!-- TRUST -->
        <div class="hero-trust hero-anim hero-anim-trust">
          <div class="trust-item">
            <div class="trust-icon">
              <Icon name="lucide:check-circle" class="w-5 h-5 text-brand" aria-hidden="true"/>
            </div>
            <span class="font-semibold">Personal verificado</span>
          </div>
          <div class="trust-item">
            <div class="trust-icon">
              <Icon name="lucide:shield-check" class="w-5 h-5 text-brand" aria-hidden="true"/>
            </div>
            <span class="font-semibold">Garantía de servicio</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>

/* WRAPPER */
.hero-wrapper{
  background:white;
}

/* HERO */
.hero{
  position:relative;
  min-height:85vh;
  overflow:hidden;
}

/* BACKGROUND */
.hero-bg{
  position:absolute;
  height:100%;
  inset:0;
}

.hero-bg-img{
  width:100%;
  height:100%;
  object-fit:cover;
}

/* CONTENT */
.hero-content{
  max-width:560px;
}

/* TITLE */
.hero-title{
  font-size:clamp(2.6rem,4vw,3.8rem);
  font-weight:800;
  line-height:1.1;
  margin-bottom:20px;
}
.hero-title span{
  display:block;
  color:var(--color-brand);
}

/* DESCRIPTION */
.hero-description{
  font-size:1.15rem;
  line-height:1.7;
  color:var(--color-gray);
  margin-bottom:34px;
  font-weight:500;
}

/* BUTTONS */
.hero-buttons{
  display:flex;
  gap:16px;
  flex-wrap:wrap;
  margin-bottom:32px;
}

/* BOTON HOVER */
.hero-buttons a{
  transition:transform .25s ease, box-shadow .25s ease;
}

.hero-buttons a:hover{
  transform:translateY(-2px);
}

/* TRUST */
.hero-trust{
  display:flex;
  gap:26px;
}

.trust-item{
  display:flex;
  align-items:center;
  gap:10px;
  font-size:.95rem;
  font-weight:500;
  color:#374151;
}

/* ICON */
.trust-icon{
  width:32px;
  height:32px;
  border-radius:10px;
  display:flex;
  align-items:center;
  justify-content:center;
  background:#f3f4f6;
}

.trust-icon svg{
  width:18px;
  height:18px;
}

/* HERO ANIMATIONS */
.hero-anim{
  opacity:0;
  transform:translateY(30px);
  animation:heroFadeUp .8s ease forwards;
}

.hero-anim-title{
  animation-delay:.2s;
}

.hero-anim-desc{
  animation-delay:.4s;
}

.hero-anim-buttons{
  animation-delay:.6s;
}

.hero-anim-trust{
  animation-delay:.8s;
}

@keyframes heroFadeUp{
  to{
    opacity:1;
    transform:translateY(0);
  }
}

/* MOBILE */
@media(max-width:768px){

.hero{
  min-height:70vh;
}

.hero-content{
  text-align:center;
  margin:auto;
}

.hero-buttons{
  justify-content:center;
}

.hero-trust{
  justify-content:center;
}


}
</style>