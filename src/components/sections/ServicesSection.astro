---
// src/components/sections/ServicesSection.astro
import SectionHeader from '@/components/sections/SectionHeader.astro';
import ServiceCard from '@/components/ui/ServiceCard.astro';
import ButtonPrimary from '@/components/ui/ButtonPrimary.astro';
import type { Servicio } from '@/types/servicio';

interface Props {
  servicios: Servicio[];
}

const { servicios } = Astro.props;

// Mostrar solo los primeros 4 servicios en la home
const featuredServices = servicios.slice(0, 4);
---

<section class="section-padding bg-light-surface" id="servicios">
  <div class="container-site">
    <SectionHeader 
      title="Nuestros Servicios de Personal Doméstico" 
      eyebrow="Especialistas en Lima" 
      subtitle="Ofrecemos soluciones integrales y seguras para el cuidado de tu familia y hogar, con personal rigurosamente evaluado."
      align="center"
        showHearts = {true}
      variant="gradient"
    />

    <div class="grid-services mt-12 mb-10">
      {featuredServices.map(servicio => (
        <ServiceCard servicio={servicio} />
      ))}
    </div>
<!-- 
    <div class="flex justify-center">
      <ButtonPrimary 
        label="Ver todos los servicios" 
        href="/nuestros-servicios" 
        variant="outline" 
        size="lg" 
      />
    </div>
    -->
  </div>
</section>
