---
// src/components/sections/HistorySection.astro
import { Image } from 'astro:assets';

interface Props {
  history: string;
  principalSedeImg: any;
  redEmpleoImg: any;
}

const { history, principalSedeImg, redEmpleoImg } = Astro.props;
---

<section class="section-padding bg-white relative overflow-hidden">
  <div class="container-site">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="order-2 lg:order-1">
        <div class="relative group">
          <div class="absolute -inset-4 bg-brand/5 rounded-2xl blur-xl group-hover:bg-brand/10 transition-colors"></div>
          <Image 
            src={principalSedeImg} 
            alt="Sede principal de El Hogar de Nanis en Lima" 
            class="relative rounded-2xl shadow-xl border border-border/50 w-full h-auto"
            width={600}
            height={400}
          />
        </div>
      </div>
      <div class="order-1 lg:order-2 flex flex-col gap-6">
        <span class="section-eyebrow">Nuestra Historia</span>
        <h2 class="section-title text-dark">Trayectoria de Confianza</h2>
        <p class="text-lg text-gray leading-relaxed">
          {history}
        </p>
        <div class="flex flex-wrap gap-4 mt-4">
          <Image 
            src={redEmpleoImg} 
            alt="Certificación Red Empleo Seguro" 
            class="h-20 w-auto grayscale contrast-125 opacity-70 hover:grayscale-0 hover:opacity-100 transition-all"
            width={150}
            height={80}
          />
        </div>
      </div>
    </div>
  </div>
</section>
