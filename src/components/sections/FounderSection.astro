---
// src/components/sections/FounderSection.astro
import FounderCard from '@/components/ui/FounderCard.astro';

interface Props {
  founder: {
    name: string;
    role: string;
    bio: string;
    image: {
      alt: string;
    };
  };
  marcelaImg: any;
}

const { founder, marcelaImg } = Astro.props;
---

<section class="section-padding bg-light-surface overflow-hidden">
  <div class="container-site">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div class="flex justify-center md:justify-end relative">
        <div class="absolute inset-0 bg-brand/10 rounded-full blur-3xl opacity-50 max-w-sm mx-auto"></div>
        <FounderCard imageSrc={marcelaImg} altText={founder.image.alt} />
      </div>
      <div class="flex flex-col gap-6 text-center md:text-left">
        <span class="section-eyebrow">Nuestro Liderazgo</span>
        <h2 class="section-title text-dark">Una visión de madre y profesional</h2>
        <p class="text-lg text-gray leading-relaxed italic">
          "{founder.bio}"
        </p>
        <div class="h-1 w-20 bg-brand/50 rounded-full"></div>
        <p class="text-gray font-medium">
          "Entiendo que cada familia es única y tiene diferentes necesidades en diferentes momentos."
        </p>
      </div>
    </div>
  </div>
</section>
