---
// src/components/sections/NavBar.astro

import ButtonPrimary from '@/components/ui/ButtonPrimary.astro';
import { Icon } from 'astro-icon/components';
import siteData from '../../../public/data/site.json';
import CopyButton from '@/components/ui/CopyButton.astro';

const links = [
  { label: 'Inicio', href: '/' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Nosotros', href: '#quienes-somos' },
  { label: 'Cómo Trabajamos', href: '#como-trabajamos' },
  { label: 'Bolsa de Trabajo', href: '/bolsa-de-trabajo' },
];

const currentPath = Astro.url.pathname;
const phone = siteData.contact.phone;
---

<header-nav class="contents">
<header class="sticky top-0 z-50 w-full bg-white/95 backdrop-blur-md border-b border-border transition-colors duration-300">
  <div class="container-site h-20 flex items-center justify-between">
    
    {/* Logo */}
    <a href="/" class="flex items-center  group" aria-label={`Ir a inicio de ${siteData.name}`}>
  <img src ="images/logo2.webp" alt="Logo El Hogar de Nanis" class="w-12 h-12"/>
      <span class="font-display leading-none w-15 font-semibold text-sm text-dark group-hover:text-brand-alt transition-colors hidden sm:flex">
        El Hogar de Nanis
      </span>
    </a>

    {/* Menú Desktop */}
    <nav class="hidden lg:flex items-center gap-6" aria-label="Navegación principal">
      <ul class="flex items-center gap-1">
        {links.map(link => {
          // Normalize paths for matching
          const isCurrent = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
          
          return (
            <li>
              <a 
                href={link.href} 
                class="nav-link" 
                aria-current={isCurrent ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    {/* CTAs y Mobile toggler */}
    <div class="flex items-center gap-4">

      <ButtonPrimary label="Contacto" href="/contacto" size="sm" variant="gradient" />
      
      {/* Botón menú mobile */}
      <button 
        id="mobile-menu-button"
        class="lg:hidden p-2 text-dark hover:text-brand-alt transition-colors" 
        aria-label="Abrir menú" 
        aria-expanded="false" 
        aria-controls="mobile-menu"
      >
        <Icon name="lucide:menu" class="w-6 h-6" />
      </button>
    </div>

  </div>
</header>

  {/* Mobile Menu Drawer */}
  <div 
    id="mobile-menu-overlay" 
    class="fixed inset-0 bg-dark/60 backdrop-blur-sm z-40 opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"
    aria-hidden="true"
  ></div>

  <div 
    id="mobile-menu" 
    class="fixed top-0 right-0 bottom-0 w-[280px] sm:w-[320px] bg-white z-50 translate-x-full transition-transform duration-300 ease-spring lg:hidden border-l border-border flex flex-col shadow-2xl"
    aria-labelledby="mobile-menu-title"
    role="dialog"
    aria-modal="true"
  >
    <div class="h-20 flex items-center justify-between px-6 border-b border-border bg-light-surface/50">
      <span id="mobile-menu-title" class="font-display font-bold text-brand uppercase tracking-wider">Menú</span>
      <button 
        id="mobile-menu-close" 
        class="p-2 text-gray-muted hover:text-brand-alt transition-colors" 
        aria-label="Cerrar menú"
      >
        <Icon name="lucide:x" class="w-6 h-6" />
      </button>
    </div>

    <nav class="flex-1 overflow-y-auto py-6 px-6">
      <ul class="flex flex-col gap-4">
        {links.map(link => {
          const isCurrent = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
          return (
            <li>
              <a 
                href={link.href} 
                class={`flex items-center py-2 text-lg font-medium transition-colors ${isCurrent ? 'text-brand-alt' : 'text-gray hover:text-brand-alt'}`}
                aria-current={isCurrent ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
      
      <div class="mt-8 pt-8 border-t border-border flex flex-col gap-6">
        <div class="flex items-center justify-between group/mobile-phone">
          <div class="flex flex-col gap-1">
            <span class="text-xs font-bold text-gray-muted uppercase tracking-widest">Llámanos</span>
            <a href={`tel:${phone}`} class="text-lg font-display font-bold text-dark">
              {phone.replace(/(\d{3})(\d{3})(\d{3})/, '$1 $2 $3')}
            </a>
          </div>
          <CopyButton 
            textToCopy={phone.replace(/\s/g, '')} 
            label="Copiar teléfono" 
            size="md"
          />
        </div>
        <ButtonPrimary label="Contacto" href="/contacto" variant="gradient" fullWidth />
      </div>
    </nav>
  </div>
</header-nav>

<script>
  class HeaderNav extends HTMLElement {
    constructor() {
      super();
      const button = this.querySelector('#mobile-menu-button') as HTMLButtonElement | null;
      const closeBtn = this.querySelector('#mobile-menu-close') as HTMLButtonElement | null;
      const menu = this.querySelector('#mobile-menu') as HTMLElement | null;
      const overlay = this.querySelector('#mobile-menu-overlay') as HTMLElement | null;
      
      if (!button || !menu || !overlay || !closeBtn) return;

      const toggleMenu = (show: boolean) => {
        button.setAttribute('aria-expanded', show.toString());
        if (show) {
          menu.classList.remove('translate-x-full');
          overlay.classList.remove('opacity-0', 'pointer-events-none');
          document.body.style.overflow = 'hidden';
          // Manejo de foco para accesibilidad
          setTimeout(() => closeBtn.focus(), 100);
        } else {
          menu.classList.add('translate-x-full');
          overlay.classList.add('opacity-0', 'pointer-events-none');
          document.body.style.overflow = '';
        }
      };

      button.addEventListener('click', () => toggleMenu(true));
      closeBtn.addEventListener('click', () => {
        toggleMenu(false);
        button.focus();
      });
      overlay.addEventListener('click', () => toggleMenu(false));

      // Cerrar al presionar Escape
      this.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape' && button.getAttribute('aria-expanded') === 'true') {
          toggleMenu(false);
          button.focus();
        }
      });

      // Cerrar al hacer clic en un enlace
      const navLinks = menu.querySelectorAll('a');
      navLinks.forEach(link => {
        link.addEventListener('click', () => toggleMenu(false));
      });
    }
  }

  customElements.define('header-nav', HeaderNav);
</script>
