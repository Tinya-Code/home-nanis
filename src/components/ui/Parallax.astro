---
// src/components/ui/Parallax.astro
import type { ImageMetadata } from 'astro';
interface Props {
  /** URL de la imagen de fondo */
  imageSrc: string | ImageMetadata;
  /** Altura del bloque (ej: 'h-[400px]', 'h-[60vh]', etc.) */
  height?: string;
  /** Posición de la imagen de fondo (ej: 'center', 'top', 'bottom', 'center 20%') */
  imagePosition?: string;
  /** Opacidad del overlay (0 a 1) */
  overlayOpacity?: number;
  /** Color del overlay (hex o nombre de color) */
  overlayColor?: string;
  /** Si el contenido debe estar dentro de un contenedor estándar */
  container?: boolean;
  /** Clases adicionales para el contenedor principal */
  class?: string;
}

const {
  imageSrc,
  height = 'h-[50vh]',
  imagePosition = 'center',
  overlayOpacity = 0.3,
  overlayColor = '#000000',
  container = false,
  class: className = '',
} = Astro.props;

const bgUrl = typeof imageSrc === 'object' ? imageSrc.src : imageSrc;

const overlayStyle = {
  backgroundColor: overlayColor,
  opacity: overlayOpacity,
};
---

<div
  class:list={[
    "parallax-window relative overflow-hidden",
    height,
    className
  ]}
>
  {/* 
      Capa de Fondo: 
      Usamos position: fixed a través de un contenedor con clip-path.
      Esto crea el efecto de "ventana" que revela la imagen.
  */}
  <div class="parallax-fixed-bg pointer-events-none">
    <div 
      class="bg-image"
      style={{
        backgroundImage: `url('${bgUrl}')`,
        backgroundPosition: imagePosition
      }}
    ></div>
  </div>

  {/* Overlay */}
  <div 
    class="absolute inset-0 pointer-events-none z-1" 
    style={overlayStyle}
  ></div>

  {/* Content */}
  <div class:list={[
    "relative z-10 h-full w-full flex items-center justify-center",
    { "container-site": container }
  ]}>
    <slot />
  </div>
</div>

<style>
  .parallax-window {
    /* El truco mágico: clip-path permite que el hijo fixed solo se vea en esta área */
    clip-path: inset(0);
    z-index: 1;
  }

  .parallax-fixed-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    /* Evita parpadeos en algunos navegadores */
    transform: translateZ(0);
  }

  .bg-image {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-repeat: no-repeat;
  }

  /* Ajuste para móviles si es necesario, 
     aunque clip-path + fixed suele ser más estable que bg-fixed */
  @media (hover: none) and (pointer: coarse) {
    /* Optativo: si en móviles prefieres algo más sencillo, 
       pero clip-path es moderno y soportado. */
  }
</style>
