---
// src/components/ui/ServiceCard.astro

import type { Servicio } from '@/types';
import ButtonPrimary from '@/components/ui/ButtonPrimary.astro';

/**
 * ServiceCard
 * ─────────────────
 * Descripción: Tarjeta de servicio responsiva con título, descripción y action.
 * Props obligatorias: servicio
 */

import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

interface Props {
  servicio: Servicio;
}

const { servicio } = Astro.props;

// Mapeo dinámico de imágenes de assets para que Astro las optimice
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/*.{jpeg,jpg,png,gif,webp}');
const imagePath = `/src/assets/${servicio.image.localPath.split('/').pop()}`;
---

<article class="card-service group">
  {/* Img container */}
  <div class="relative w-full aspect-video rounded overflow-hidden bg-surface-alt">
    {images[imagePath] ? (
      <Image 
        src={images[imagePath]()} 
        alt={servicio.image.alt}
        width={400}
        height={225}
        loading="lazy"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    ) : (
      <img 
        src={servicio.image.localPath.replace('public/', '/')} 
        alt={servicio.image.alt}
        loading="lazy"
        class="w-full h-full object-cover"
      />
    )}
  </div>

  <div class="flex flex-col flex-1 gap-3">
    <h3 class="font-body font-semibold text-xl text-brand">{servicio.title}</h3>
    <p class="text-sm text-gray flex-1">{servicio.shortDescription}</p>
    
    {servicio.features && servicio.features.length > 0 && (
      <ul class="flex flex-col gap-1 mb-2">
        {servicio.features.slice(0, 3).map(feature => (
          <li class="list-feature-item">
            <Icon name="lucide:check" class="list-feature-icon" />
            <span>{feature}</span>
          </li>
        ))}
      </ul>
    )}
  </div>

  <div class="mt-auto pt-4 border-t border-border flex flex-wrap gap-2 items-center justify-between">
    <ButtonPrimary label="Ver más" href={`/servicios/${servicio.id}`} variant="outline" size="sm" />
  </div>
</article>
