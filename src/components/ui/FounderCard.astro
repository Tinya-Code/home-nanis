---
// src/components/ui/FounderCard.astro
import { Image } from 'astro:assets';

interface Props {
  imageSrc: any;
  altText: string;
}

const { imageSrc, altText } = Astro.props;
---

<div class="founder-card group relative">

  <div class="image-wrapper rounded-md">
    <Image
      src={imageSrc}
      alt={altText}
      height="280"
      class="founder-image"
    />
  </div>
</div>

<style>
.founder-card{
  opacity:0;
  transform:translateY(50px);
  animation: founderEnter .9s ease forwards;
}

.image-wrapper{
  overflow:hidden;

  box-shadow:0 20px 40px rgba(0,0,0,0.12);
  transition:all .35s ease;
}

.founder-image{
  width:100%;
  height:100%;
  object-fit:cover;
  transition:transform .6s ease;
}

.founder-card:hover .image-wrapper{
  box-shadow:0 30px 60px rgba(0,0,0,0.18);
}

.founder-card:hover .founder-image{
  transform:scale(1.04);
}

@keyframes founderEnter{

  from{
    opacity:0;
    transform:translateY(60px);
  }

  to{
    opacity:1;
    transform:translateY(0);
  }
}
</style>
