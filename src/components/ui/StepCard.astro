---
// src/components/ui/StepCard.astro
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<div class="step-card">
  <div class="step-card__icon">
    <slot name="icon">
      <Icon name="lucide:check-circle" class="text-brand h-8 w-8" />
    </slot>
  </div>
  <h3 class="step-card__title">
    {title}
  </h3>
  <p class="step-card__paragraph">
    {description}
  </p>
</div>

<style>
  .step-card {
    width: 100%;
    max-width: 380px;
    margin: auto;
    padding: 1.5rem;
    background: var(--color-surface);
    border-radius: 1.5rem;
    border: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
    text-align: center;
    transition:
      transform 0.35s ease,
      box-shadow 0.35s ease;
  }

  .step-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
  }

  .step-card__icon {
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .step-card__title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 0.6rem;
  }

  .step-card__paragraph {
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--color-gray);
  }
</style>
