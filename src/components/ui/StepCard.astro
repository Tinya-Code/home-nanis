---
// src/components/ui/StepCard.astro
import { Icon } from 'astro-icon/components';

/**
 * StepCard
 * ─────────────────
 * Descripción: Representa un paso en el flujo de proceso "Cómo Trabajamos".
 * Props obligatorias: stepNumber, title, description
 */

interface Props {
  stepNumber: number | string;
  title: string;
  description: string;
}

const { stepNumber, title, description } = Astro.props;
---

<div class="step-card">
  <div class="step-card__body">
    <div class="step-card__icon">
      <slot name="icon">
        <Icon name="lucide:check-circle" class="w-8 h-8 text-brand" />
      </slot>
    </div>

    <h3 class="step-card__title">{title}</h3>
    <p class="step-card__paragraph">
      {description}
    </p>
  </div>

  <div class="step-card__ribbon">
    <label class="step-card__ribbon-label">{stepNumber}</label>
  </div>
</div>

<style>
  .step-card {
    --brand-main: #810FC9;
    --brand-dark: #6A0DAD;
    --brand-bg: #f4f5f2;
    
    width: 100%;
    max-width: 320px;
    margin: auto;
    background-color: var(--color-surface);
    text-align: center;
    border-top-left-radius: 4rem;
    border: 2px solid #fff;
    position: relative;
    padding-bottom: 2rem;
    transition: transform 0.3s ease;
  }

  .step-card:hover {
    transform: translateY(-5px);
  }

  .step-card::before {
    content: "";
    position: absolute;
    height: 30px;
    width: 120px;
    background-color: var(--brand-main);
    top: 32px;
    right: -2.5px;
    -webkit-clip-path: polygon(10% 0, 100% 0, 100% 100%, 0 100%);
    clip-path: polygon(10% 0, 100% 0, 100% 100%, 0 100%);
  }

  .step-card__body {
    padding: 3rem 1.5rem 1rem;
    max-width: 25ch;
    margin: auto;
  }

  .step-card__icon {
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .step-card__title {
    font-weight: 800;
    color: var(--color-dark);
    font-size: 1.25rem;
    margin-block: 1rem 0.5rem;
  }

  .step-card__paragraph {
    color: var(--color-gray);
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .step-card__ribbon {
    margin-top: 1rem;
    display: grid;
    place-items: center;
    height: 50px;
    background-color: var(--brand-main);
    position: relative;
    width: 110%;
    left: -5%;
    top: 10px;
    border-radius: 0 0 2rem 2rem;
  }

  .step-card__ribbon::after,
  .step-card__ribbon::before {
    content: "";
    position: absolute;
    width: 20px;
    aspect-ratio: 1/1;
    bottom: 100%;
    z-index: -1;
    background-color: var(--brand-dark);
  }

  .step-card__ribbon::before {
    left: 0;
    transform-origin: left bottom;
    transform: rotate(45deg);
  }

  .step-card__ribbon::after {
    right: 0;
    transform-origin: right bottom;
    transform: rotate(-45deg);
  }

  .step-card__ribbon-label {
    display: flex;
    width: 60px;
    aspect-ratio: 1/1;
    background-color: #fff;
    position: relative;
    transform: translateY(-50%);
    border-radius: 50%;
    border: 6px solid var(--brand-main);
    place-items: center;
    justify-content: center;
    font-weight: 900;
    line-height: 1;
    font-size: 1.25rem;
    color: var(--brand-main);
  }

  .step-card__ribbon-label::before,
  .step-card__ribbon-label::after {
    content: "";
    position: absolute;
    width: 20px;
    height: 20px;
    bottom: 50%;
  }

  .step-card__ribbon-label::before {
    right: calc(100% + 2px);
    border-bottom-right-radius: 20px;
    box-shadow: 5px 5px 0 var(--brand-main);
  }

  .step-card__ribbon-label::after {
    left: calc(100% + 2px);
    border-bottom-left-radius: 20px;
    box-shadow: -5px 5px 0 var(--brand-main);
  }
</style>
