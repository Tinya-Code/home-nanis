---
// src/components/ui/JobBenefit.astro
import { Icon } from 'astro-icon/components';

interface Props {
  benefit: string;
  icon?: string;
  class?: string;
}

const { benefit, icon = 'lucide:heart', class: className = '' } = Astro.props;
---

<div class:list={[
  "p-6 rounded-2xl border border-border bg-section-alt flex flex-col gap-3 group hover:bg-brand/5 hover:border-brand/20 transition-all duration-300",
  className
]}>
  <div class="w-10 h-10 rounded-xl bg-brand/5 flex items-center justify-center text-brand-alt group-hover:bg-brand group-hover:text-white transition-all duration-300">
    <Icon name={icon} class="w-5 h-5 group-hover:scale-110 transition-transform" />
  </div>
  <p class="text-sm text-gray font-medium leading-relaxed">{benefit}</p>
</div>
