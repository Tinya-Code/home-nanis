---
// src/components/ui/SkipLink.astro
interface Props {
  targetId?: string;
  label?: string;
}

const { 
  targetId = 'main-content', 
  label = 'Saltar al contenido principal' 
} = Astro.props;
---

<a
  href={`#${targetId}`}
  class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4
         focus:z-[100] focus:px-4 focus:py-2 focus:bg-brand focus:text-white
         focus:rounded-md focus:font-bold focus:shadow-lg focus:outline-none 
         focus:ring-2 focus:ring-brand focus:ring-offset-2
         transition-all duration-200"
>
  {label}
</a>
