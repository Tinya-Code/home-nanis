---
// src/components/ui/FormInput.astro
interface Props {
  label: string;
  id: string;
  type?: 'text' | 'email' | 'tel' | 'number';
  required?: boolean;
  placeholder?: string;
  textarea?: boolean;
  rows?: number;
}

const { label, id, type = 'text', required = false, placeholder, textarea = false, rows = 4 } = Astro.props;
---

<div class="flex flex-col gap-2">
  <label class="text-sm font-bold text-dark" for={id}>
    {label} {required && <span class="text-brand-alt">*</span>}
  </label>
  
  {textarea ? (
    <textarea 
      id={id} 
      name={id} 
      required={required} 
      placeholder={placeholder} 
      rows={rows} 
      class="form-input resize-none"
    ></textarea>
  ) : (
    <input 
      type={type} 
      id={id} 
      name={id} 
      required={required} 
      placeholder={placeholder} 
      class="form-input" 
    />
  )}
</div>

<style>
  .form-input {
    width: 100%;
    padding: 0.75rem 1.25rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-light-border);
    background-color: var(--color-light-surface);
    color: var(--color-dark);
    outline: none;
    transition: all 0.3s ease;
  }
  .form-input:focus {
    border-color: var(--color-brand);
    box-shadow: 0 0 0 2px rgba(var(--brand-rgb), 0.2);
  }
  .form-input::placeholder {
    color: var(--color-gray-muted);
  }
</style>
