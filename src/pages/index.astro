---
// src/pages/index.astro
import Footer from '@/components/sections/Footer.astro';
import Layout from '@/layouts/Layout.astro';
// Home Sections
import CertBadgesSection from '@/components/sections/CertBadgesSection.astro';
import ContactSection from '@/components/sections/ContactSection.astro';
import CTASection from '@/components/sections/CTASection.astro';
import FAQSection from '@/components/sections/FAQSection.astro';
import FounderSection from '@/components/sections/FounderSection.astro';
import HeroSection from '@/components/sections/HeroSection.astro';
import ProcessSection from '@/components/sections/ProcessSection.astro';
import ServicesSection from '@/components/sections/ServicesSection.astro';
import TestimonialsSection from '@/components/sections/TestimonialsSection.astro';
import VideoSection from '@/components/sections/VideoSection.astro';
import WhyUsSection from '@/components/sections/WhyUsSection.astro';
import Parallax from '@/components/ui/Parallax.astro';
// Data
import type { ContactData, FAQData, SiteData } from '@/types';
import contactDataRaw from '@/data/contacto.json';
import faqsDataRaw from '@/data/faqs.json';

import bannerParalax from '@/assets/banner-paralax-1.webp'

import quienesSomosRaw from '@/data/quienes-somos.json';
import serviciosRaw from '@/data/servicios.json';
import siteDataRaw from '@/data/site.json';
import testimoniosData from '@/data/testimonios.json';
const siteData = siteDataRaw as SiteData;


// Assets
import marcelaImg from '@/assets/marcelacubillos.jpeg';

import { buildLocalBusiness } from '@/lib/jsonld';

const servicios = Array.isArray(serviciosRaw) ? serviciosRaw : Object.values(serviciosRaw);
const contactData = contactDataRaw as unknown as ContactData;
const faqData = faqsDataRaw as FAQData;
const founder = (quienesSomosRaw as any).founder;

// Preparar Schema LocalBusiness con AggregateRating para la Home
const homeSchema = buildLocalBusiness(siteData.localSeo.schemaLocalBusiness, {
  score: testimoniosData.globalRating.score.toString(),
  count: testimoniosData.globalRating.totalReviews
});
---

<Layout
  title={siteData.name}
  description={siteData.shortDescription}
>
  <script is:inline slot="head" type="application/ld+json" set:html={homeSchema} />

  <main id="main-content" tabindex="-1">
    <HeroSection />

    <ServicesSection servicios={servicios as any[]} />
    <WhyUsSection />
    <ProcessSection />
    <VideoSection videos={siteData.videos} />
    <Parallax 
      imageSrc={bannerParalax}
      class="h-[60vh]" 
    />
    <TestimonialsSection testimonios={testimoniosData.reviews} />
    <CTASection />
    <FounderSection founder={founder} marcelaImg={marcelaImg} />
    <FAQSection faqData={faqData} limit={6} />
    <ContactSection contactData={contactData} />
        <CertBadgesSection />
  </main>

  <Footer />
</Layout>
