---
// src/pages/bolsa-de-trabajo.astro
import Layout from '@/layouts/Layout.astro';
import Footer from '@/components/sections/Footer.astro';
import PageHeader from '@/components/sections/PageHeader.astro';
import JobListingSection from '@/components/sections/JobListingSection.astro';
import CTASection from '@/components/sections/CTASection.astro';
import Parallax from '@/components/ui/Parallax.astro';
import type { JobBoardData } from '@/types';
import bannerBolsaTrabajo from '@/assets/banner-bolsa-trabajo.webp'
import dataRaw from '../../public/data/empleo.json';
import JobRequirementsBenefits from '@/components/sections/JobRequirementsBenefits.astro';
import bannerParalax from '@/assets/banner-paralax-2.webp'

const data = dataRaw as unknown as JobBoardData;
const { seo, title, subtitle, description, requirements, benefits, jobOffers, applicationForm } = data;
---

<Layout title={seo.title} description={seo.description}>
    
  <main id="main-content">
    <PageHeader 
      title={title} 
      subtitle={subtitle} 
      variant="image"
      align="left"
      backgroundImage={bannerBolsaTrabajo}
      breadcrumbs={[{ label: 'Bolsa de Trabajo' }]}
    />

    {/* Introduction */}
    <section class="pt-16 bg-white">
      <div class="container-site">
        <div class="max-w-4xl mx-auto">
          <p class="text-lg text-gray-muted leading-relaxed italic">
            "{description}"
          </p>
        </div>
      </div>
    </section>

    {/* Requirements & Benefits */}
    <JobRequirementsBenefits 
      requirements={requirements}
      benefits={benefits}
    />

    {/* Job Offers Section */}
    <JobListingSection jobOffers={jobOffers} />
        <Parallax 
      imageSrc={bannerParalax}
      height="h-[60vh]"
    />

    {/* Application Form Banner (now using CTASection variant) */}
    <CTASection 
      title={applicationForm.title}
      subtitle="Formulario de Postulación"
      description={applicationForm.description}
      variant="dark"
      primaryButton={{
        label: "Llenar Formulario Digital",
        href: applicationForm.link,
        icon: "lucide:external-link",
        external: true
      }}
      secondaryButton={{
        label: "Consultar dudas",
        href: "https://wa.me/51941141780",
        icon: "lucide:message-circle",
        variant: "outline"
      }}
      iconLarge="lucide:file-user"
    />

    {/* Footer CTA */}



  </main>

  <Footer />
</Layout>
